# Backend API base. When live, point this at the running backend.
VITE_API_BASE=https://api.edu.aajneeti.social/api/v1

# Use bundled JSON fixtures instead of the live API. Set false once the API is reachable.
VITE_USE_MOCK=false

# Keep the site out of search indexes (noindex meta + robots Disallow: /).
# Defaults to true when unset. Decoupled from VITE_USE_MOCK so the site can run
# on real data and stay unindexed. Set false only at approved public launch.
VITE_NOINDEX=true

# Display name for the portal. Single source of truth for the brand placeholder.
VITE_SITE_NAME=ACL Education Portal

# Public site origin, used for canonical URLs and sitemap.
# For the Vercel mock preview, set this to the deployment URL.
VITE_SITE_ORIGIN=http://localhost:3000

# GA4 measurement id (leave blank to disable analytics).
VITE_GA4_ID=

# Google Ads conversion id, e.g. AW-XXXXXXXXXX (leave blank to disable Ads tag).
VITE_GOOGLE_ADS_ID=

# Optional Google Ads conversion label (part after the slash in send_to). When
# set, the /thank-you page fires a conversion to AW-XXXXXXXXXX/label.
VITE_GOOGLE_ADS_CONVERSION_LABEL=

# Site-wide contact details (footer + contact page). Defaults baked into config.
VITE_CONTACT_EMAIL=
VITE_CONTACT_PHONE=

# --- Vercel mock preview (set these as Project Environment Variables, then redeploy) ---
# VITE_USE_MOCK=true   (drives sample data, simulated OTP/lead, preview ribbon)
# VITE_NOINDEX=true    (drives site-wide noindex meta + robots disallow; keep true until public launch)
# VITE_SITE_ORIGIN=https://acl-portal-frontend.vercel.app
# VITE_API_BASE is unused while VITE_USE_MOCK=true.
# Note: VITE_ vars are baked in at build time, so a redeploy is required after changing them.
