# Backend API base. When live, point this at the running backend.
VITE_API_BASE=http://localhost:8000/api/v1

# Use bundled JSON fixtures instead of the live API. Set false once the API is reachable.
VITE_USE_MOCK=true

# Display name for the portal. Single source of truth for the brand placeholder.
VITE_SITE_NAME=ACL Education Portal

# Public site origin, used for canonical URLs and sitemap.
# For the Vercel mock preview, set this to the deployment URL.
VITE_SITE_ORIGIN=http://localhost:3000

# GA4 measurement id (leave blank to disable analytics).
VITE_GA4_ID=

# --- Vercel mock preview (set these as Project Environment Variables, then redeploy) ---
# VITE_USE_MOCK=true   (drives sample data, site-wide noindex, robots disallow, preview ribbon)
# VITE_SITE_ORIGIN=https://acl-portal-frontend.vercel.app
# VITE_API_BASE is unused while VITE_USE_MOCK=true.
# Note: VITE_ vars are baked in at build time, so a redeploy is required after changing them.
